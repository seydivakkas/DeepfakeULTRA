{
  "manifest_version": 3,
  "name": "DeepfakeULTRA — Deepfake Detector",
  "description": "Web'deki görsellere sağ tıklayarak deepfake analizi yapın. AI-powered forensik tespit.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:7860/*",
    "http://127.0.0.1:7860/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "DeepfakeULTRA"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:7860/*",
        "http://127.0.0.1:7860/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
